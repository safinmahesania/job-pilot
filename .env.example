# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real tokens.

# ── Telegram notifications (optional) ──
# 1. Create a bot with @BotFather and copy the token it gives you.
# 2. Message your new bot once, then open:
#      https://api.telegram.org/bot<TOKEN>/getUpdates
#    and read the numeric "chat":{"id": ...} value.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Application-document generation (optional) ──
# The cover-letter generator tries these in order, then falls back to local
# Ollama. Both have free tiers with no credit card:
#   Gemini   -> https://aistudio.google.com/apikey
#   Cerebras -> https://cloud.cerebras.ai   (API Keys page)
# Leave blank to use only local Ollama.
GEMINI_API_KEY=
CEREBRAS_API_KEY=

# ── Job search APIs (optional) ──
# JSearch searches the whole web (LinkedIn, Indeed, Glassdoor, …) via Google for Jobs.
# Add a source with `ats: jsearch` in companies-backup.yaml to use it. Free key from:
#   RapidAPI    -> https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
#   OpenWeb Ninja -> https://www.openwebninja.com/api/jsearch
# Leave blank if you don't use a jsearch source.
JSEARCH_API_KEY=

# Adzuna searches aggregated listings with salary data and an IT-jobs filter.
# Add a source with `ats: adzuna` in companies-backup.yaml to use it. Free credentials from:
#   https://developer.adzuna.com/  (register -> app_id + app_key)
# Leave blank if you don't use an adzuna source.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ── Mail ──
# There is none. JobPilot has no mail credentials and no IMAP client: an app
# password can read your entire account, and no amount of careful code makes that
# safe to hold. Export the job-alert emails you want it to see (Save as .eml or
# .html) and import them from the Settings page, or drop them in data/mail_drop/.


# ── Deployment: the lock on the door ──
# Set this before exposing the app on any public URL. Every request must then carry
# the password (a browser logs in once and gets a cookie; the extension sends it as
# an x-jobpilot-key header). Leave it BLANK for local development — the gate is off,
# and the app stays reachable on localhost as before.
#
# Generate a strong one:  python -c "import secrets; print(secrets.token_urlsafe(24))"
JOBPILOT_PASSWORD=
